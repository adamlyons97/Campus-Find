rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsItemData(item) {
      return (item.keys().hasAll(['owner_uid'])
              && item.owner_uid == request.auth.uid)
          || ((!item.keys().hasAll(['owner_uid']) || item.owner_uid == '')
              && item.contact == request.auth.token.email);
    }

    function ownsItem(itemId) {
      return ownsItemData(
        get(/databases/$(database)/documents/items/$(itemId)).data
      );
    }

    match /profiles/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.owner_uid == request.auth.uid;

      allow update: if signedIn()
          && ownsItemData(resource.data)
          && request.resource.data.owner_uid == request.auth.uid;

      allow delete: if signedIn()
          && ownsItemData(resource.data);
    }

    match /claims/{claimId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.claimant_uid == request.auth.uid
          && !ownsItem(request.resource.data.item_id);

      allow update: if signedIn()
          && ownsItem(resource.data.item_id)
          && request.resource.data.item_id == resource.data.item_id
          && request.resource.data.claimant_uid == resource.data.claimant_uid;

      allow delete: if signedIn()
          && ownsItem(resource.data.item_id);
    }
  }
}
