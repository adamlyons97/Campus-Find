rules_version = '2';

// CampusFind Firestore security rules.
// Mirrors the data model in Section 9 and enforces the Shariah-compliant
// claim flow: only the rightful authorities (security/admin) may approve
// or reject a claim, while any signed-in member may report and claim items.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isVerifier() {
      return isSignedIn() && myProfile().role in ['security', 'admin'];
    }

    // users: a member can read any profile but only write their own.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // items: anyone signed in can read active items and create reports.
    // Only the reporter (or a verifier) may update; status changes to
    // 'resolved' happen via the claim approval batch.
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.reporterId == request.auth.uid || isVerifier());
      allow delete: if false; // use soft delete only
    }

    // itemCategories: read-only lookup for clients; managed in console.
    match /itemCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isVerifier();
    }

    // claims: a member can create a claim and read their own; verifiers can
    // read all and are the only ones permitted to approve/reject.
    match /claims/{claimId} {
      allow read: if isSignedIn()
        && (resource.data.claimantId == request.auth.uid
            || resource.data.reporterId == request.auth.uid
            || isVerifier());
      allow create: if isSignedIn()
        && request.resource.data.claimantId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isVerifier();
      allow delete: if false;
    }
  }
}
